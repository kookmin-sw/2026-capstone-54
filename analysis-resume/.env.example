OPENAI_API_KEY=your-openai-api-key


# ── Celery (broker/result backend 는 mefit-redis 와 공유) ──────
# CELERY_BROKER_URL=redis://mefit-redis:6379/0
# CELERY_RESULT_BACKEND=redis://mefit-redis:6379/1

# ── S3 / 파일 스토리지 ───────────────────────────
# 개발: S3Mock (mefit-local 네트워크 내 mefit-s3mock 컨테이너)
AWS_STORAGE_BUCKET_NAME=mefit-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://mefit-s3mock:9090
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
