CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3 (audio download)
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# faster-whisper
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_DEFAULT_LANGUAGE=ko

# backend callback
BACKEND_CALLBACK_TASK_NAME=interviews.tasks.save_transcript_result_task.SaveTranscriptResultTask
BACKEND_CALLBACK_QUEUE=celery

LOG_LEVEL=INFO
