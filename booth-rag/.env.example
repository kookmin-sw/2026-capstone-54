# booth-rag 부스 클라이언트 — 환경 변수 템플릿
# ─────────────────────────────────────────────────────────────────────
# 실제 값으로 바꾸어 .env 파일로 복사하세요. .env 는 절대 커밋 금지.
#
# 이 파일은 부스 챗봇이 도는 클라이언트 머신용입니다. 임베딩 서버를
# 별도 머신 (예: 맥 스튜디오) 에 띄우는 경우 그 머신에서는 .env.server.sample
# 을 복사해서 사용하세요.
#
# 기본값은 "모든 기능 ON" 으로 세팅되어 있습니다 (듀얼 임베딩, 리랭커,
# 멀티홉 그래프, 반복 검색). 필요 없는 기능은 false / 작은 값으로 끄세요.

# ─── 임베딩 백엔드 ──────────────────────────────────────────────────────
# local  = 이 머신에서 직접 sentence-transformers 로 임베딩
# remote = 다른 머신 (맥 스튜디오 등) 의 임베딩 서버 호출 (권장)
EMBEDDING_BACKEND=remote

# 문서/한국어용 메인 모델. local 백엔드에서는 이 모델을 직접 로드,
# remote 백엔드에서는 임베딩 서버의 EMBEDDING_LOCAL_MODEL 과 같아야 함.
# 인덱스가 이미 만들어진 상태에서 모델을 바꾸려면 반드시 reset + reingest:
#   uv run python scripts/reset_index.py
#   uv run python scripts/ingest_codebase.py
#
# 추천:
#   BAAI/bge-m3                            ← 기본, 다국어, 1024-d, ~2.3GB, MIT
#   intfloat/multilingual-e5-large         ← 강력한 대안, 1024-d, ~2.2GB
#   intfloat/multilingual-e5-small         ← 가벼움, 384-d, ~470MB
EMBEDDING_LOCAL_MODEL=BAAI/bge-m3

# 디바이스: auto | cpu | mps | cuda  (auto = Apple Silicon 에서 MPS 자동)
EMBEDDING_DEVICE=auto

# 적재 시 파일 단위 병렬 임베딩 워커 수.
# 1 = 직렬 (안전, 느림).  4~8 = 로컬 추천.  16+ = 빠른 LAN 원격 서버.
# 원격 서버가 nomic-bert 계열을 들고 있고 race issue 가 다시 나오면 1 로.
EMBEDDING_CONCURRENCY=8

# ─── 원격 임베딩 (EMBEDDING_BACKEND=remote 일 때) ──────────────────────
# 임베딩 서버 (.env.server.sample 로 띄움) 의 base URL.
REMOTE_EMBEDDING_URL=http://192.168.0.6:8080
REMOTE_EMBEDDING_TIMEOUT=60.0
REMOTE_EMBEDDING_BATCH_SIZE=32

# 듀얼 임베딩 + 원격 백엔드 조합 — 코드 임베딩 전용 서버 URL.
# 같은 (혹은 다른) 머신에서 두 번째 인스턴스를 다른 포트로 띄움
# (예: nomic-ai/CodeRankEmbed @ 8081). 비워두면 코드 경로는 로컬 fallback.
REMOTE_EMBEDDING_CODE_URL=http://192.168.0.6:8081

# ─── 듀얼 임베딩 ────────────────────────────────────────────────────────
# 코드 청크 → 코드 특화 모델 (CodeRankEmbed), 문서 청크 → 다국어 모델 (bge-m3).
# 두 ChromaDB 컬렉션 (booth_rag_code 768d + booth_rag_docs 1024d) 으로 분리.
# 변경 후 반드시 reset + reingest 필요.
RAG_DUAL_EMBEDDING=true

# 코드 특화 임베딩 모델 (dual 모드에서만 사용).
# CodeRankEmbed: MIT, 137M, 768d, 8K context, CoIR 60.1
# trust_remote_code=True 로 로드되며 모델 내부 코드가 einops 사용 (deps 포함됨).
# 원격 코드 서버 사용 시 REMOTE_EMBEDDING_CODE_URL 이 우선.
EMBEDDING_CODE_MODEL=nomic-ai/CodeRankEmbed
EMBEDDING_CODE_TRUST_REMOTE_CODE=true

# ─── Graph RAG ────────────────────────────────────────────────────────────
# Personalised PageRank 기반 그래프 점수를 검색 결과에 결합
GRAPH_USE_PAGERANK=true
GRAPH_PPR_WEIGHT=0.15
GRAPH_PPR_ALPHA=0.85
GRAPH_HUB_TOP_K=5

# 그래프 확장 반경 (0=비활성, 1=1-hop, 2-3=multi-hop).
# "X 가 의존하는 모듈?" / "Y 호출하는 함수?" 류 질문에 2 이상이 유리.
GRAPH_RADIUS=2

# ─── RAG 검색 강화 ──────────────────────────────────────────────────────
# 멀티턴: 이전 대화를 반영한 standalone 검색 쿼리로 자동 재작성
RAG_REWRITE_QUERY=true

# 한 질문 → 3개 변형 (원본 / 코드 키워드 / 도메인 한국어) 생성 후 RRF 융합
RAG_EXPAND_QUERIES=true

# 다양성 (MMR) — 유사한 청크가 top-k 를 덮어쓰는 것 방지
RAG_USE_MMR=true
RAG_MMR_LAMBDA=0.7
RAG_FETCH_K=20
RAG_RRF_K=60

# HyDE — 짧은 한국어 쿼리 (예: "팀원 구성") 처럼 corpus 와 어휘 거리가 큰
# 질문에 LLM 으로 가상 답변 본문을 만들어 그것도 검색에 함께 사용. RRF 융합.
RAG_HYDE_ENABLED=true
RAG_HYDE_N=2

# BM25 — 한국어 짧은 쿼리 / 코드 식별자 (`회원가입`, `signup`, `API`) 같은
# keyword 매칭 강화. Dense 와 sparse 결과를 RRF 로 융합.
RAG_USE_BM25=true
RAG_BM25_K=10

# Cross-encoder reranker — RRF 후 top-N 을 (질문, 청크) 쌍별로 재정렬.
# bge-reranker-v2-m3: MIT, 568M, 한국어+영어 강함. 첫 호출 시 1회 다운로드.
RAG_USE_RERANKER=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_INPUT_K=20

# 반복적 검색 — 첫 답변이 "정보 없음" 등 low-confidence 패턴이면 LLM 답변
# 본문을 추가 retrieval 쿼리로 합쳐서 한 번 더 시도.
# 비-streaming answer() 경로에만 적용 (SSE 스트림은 1차 패스만 유지).
RAG_USE_ITERATIVE=true
RAG_ITERATIVE_MAX_ATTEMPTS=2

# ─── LLM 채팅 (OpenAI, 선택) ─────────────────────────────────────────────
# 비어있으면 챗봇은 검색 결과만 보여주는 fallback 모드 (LLM 호출 없음).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── 인제스션 ─────────────────────────────────────────────────────────────
# 미핏 모노레포 경로 (코드 분석 대상)
SOURCE_REPO_PATH=/Users/koa/006-capstone-modules

# 인덱싱할 최상위 디렉토리 (쉼표 구분, 공백 없음).
# 부스 챗봇에서 답변 품질이 가장 좋은 조합 — 코드 + 발표자료 + 명세.
# 팀원/조직도까지 답변하고 싶다면 /admin 에서 별도 마크다운 업로드.
INGEST_INCLUDE_DIRS=backend,frontend,analysis-resume,analysis-stt,analysis-video,face-analyzer,infra,interview-analysis-report,mefit-diagrams,mefit-tools,scraping,voice-api,presentation-docs,docs

# ─── 서버 ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
DEBUG=true

# ─── 부스 정보 (UI 표시용) ───────────────────────────────────────────────
BOOTH_TEAM_NUMBER=54
BOOTH_TEAM_NAME=미핏 (MeFit)
BOOTH_DOMAIN_URL=https://mefit.kr
BOOTH_TEAM_PAGE_URL=https://kookmin-sw.github.io/2026-capstone-54/

# ─── 관리자 ───────────────────────────────────────────────────────────────
# 빈 값이면 admin 페이지가 비활성화됨. 발표 부스에서 잠시 켤 때만 설정.
ADMIN_TOKEN=admin-token
