# booth-rag 환경 변수 템플릿
# 실제 값으로 바꾸어 .env 파일로 복사하세요. .env 는 절대 커밋 금지.

# ─── 임베딩 백엔드 ──────────────────────────────────────────────────────
# local  = 이 머신에서 직접 sentence-transformers 로 임베딩 (기본)
# remote = 다른 머신 (예: 맥 스튜디오) 의 임베딩 서버 호출
EMBEDDING_BACKEND=local

# 모델 ID. local 백엔드와 임베딩 서버 양쪽에서 같은 값을 사용해야 합니다.
# 모델을 변경하려면 먼저 인덱스를 초기화하고 다시 적재해야 합니다:
#   uv run python scripts/reset_index.py
#   uv run python scripts/ingest_codebase.py
#
# 추천 (한국어 + 영어 + 코드 친화):
#   BAAI/bge-m3                                                  ← 기본, 다국어, 1024-d, ~2.3GB
#   intfloat/multilingual-e5-large                               ← 강력한 대안, 1024-d, ~2.2GB
#   intfloat/multilingual-e5-small                               ← 가벼움, 384-d, ~470MB
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  ← 가장 가벼움, 384-d, ~470MB
EMBEDDING_LOCAL_MODEL=BAAI/bge-m3

# 디바이스: auto | cpu | mps | cuda  (auto = Apple Silicon 에서 MPS 자동)
EMBEDDING_DEVICE=auto

# ─── 원격 임베딩 (EMBEDDING_BACKEND=remote 일 때) ──────────────────────
# 맥 스튜디오 등 별도 머신에서 `bash scripts/run_embedding_server.sh` 로 띄운 서버를 가리킵니다.
# 그 머신의 EMBEDDING_LOCAL_MODEL 이 이 머신과 같아야 검색 일관성이 유지됩니다.
REMOTE_EMBEDDING_URL=http://192.168.0.6:8080
REMOTE_EMBEDDING_TIMEOUT=60.0
REMOTE_EMBEDDING_BATCH_SIZE=32

# 적재 시 파일 단위 병렬 임베딩 워커 수.
# 1 = 직렬 (이전 기본).  4~8 = 로컬 추천 (CPU/MPS 활용).  16+ = 원격 서버 빠른 LAN 추천.
# chunk_index 가 unique 라 중복 적재 자동 방지됨.
EMBEDDING_CONCURRENCY=4

# ─── Graph RAG ────────────────────────────────────────────────────────────
# Personalised PageRank 기반 그래프 점수를 검색 결과에 결합
GRAPH_USE_PAGERANK=true
GRAPH_PPR_WEIGHT=0.15
GRAPH_PPR_ALPHA=0.85
GRAPH_HUB_TOP_K=5

# ─── RAG 강화 (검색 품질) ────────────────────────────────────────────────
# 멀티턴: 이전 대화를 반영한 standalone 검색 쿼리로 자동 재작성
RAG_REWRITE_QUERY=true
# 한 질문 → 3개 변형 (원본 / 코드 키워드 / 도메인 한국어) 생성 후 RRF 융합
RAG_EXPAND_QUERIES=true
# 다양성 (MMR) — 유사한 청크가 top-k 를 덮어쓰는 것 방지
RAG_USE_MMR=true
RAG_MMR_LAMBDA=0.7
RAG_FETCH_K=20
RAG_RRF_K=60
# HyDE — 짧은 한국어 쿼리 (예: "팀원 구성") 처럼 corpus 와 어휘 거리가 큰 질문에
# LLM 으로 가상의 답변 본문을 만들어 그것도 검색에 함께 사용. RRF 로 통합.
RAG_HYDE_ENABLED=true
RAG_HYDE_N=2

# ─── 임베딩 서버 (이 머신이 서버 역할일 때만) ──────────────────────────
# `bash scripts/run_embedding_server.sh` 의 bind 주소.
EMBEDDING_SERVER_HOST=0.0.0.0
EMBEDDING_SERVER_PORT=8080

# ─── LLM 채팅 (OpenAI, 선택) ─────────────────────────────────────────────
# 비어있으면 챗봇은 검색 결과만 보여주는 fallback 모드 (LLM 호출 없음).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── 인제스션 ─────────────────────────────────────────────────────────────
# 미핏 모노레포 경로 (코드 분석 대상)
SOURCE_REPO_PATH=/Users/koa/006-capstone-modules

# 인덱싱할 최상위 디렉토리 (쉼표 구분, 공백 없음)
# 부스 챗봇에서 답변 품질이 가장 좋은 조합 — 코드 + 발표자료 + 명세
# 팀원 / 조직도까지 답변하고 싶다면 /admin 에서 별도 마크다운 업로드 권장
INGEST_INCLUDE_DIRS=backend,frontend,analysis-resume,analysis-stt,analysis-video,face-analyzer,infra,interview-analysis-report,mefit-diagrams,mefit-tools,scraping,voice-api,presentation-docs,docs

# ─── 서버 ─────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
DEBUG=true

# ─── 부스 정보 (UI 표시용) ───────────────────────────────────────────────
BOOTH_TEAM_NUMBER=54
BOOTH_TEAM_NAME=미핏 (MeFit)
BOOTH_DOMAIN_URL=https://mefit.kr
BOOTH_TEAM_PAGE_URL=https://kookmin-sw.github.io/2026-capstone-54/

# ─── 관리자 ───────────────────────────────────────────────────────────────
# 빈 값이면 admin 페이지가 비활성화됨. 발표 부스에서 잠시 켤 때만 설정.
ADMIN_TOKEN=admin-token
