# booth-rag 임베딩 서버 (별도 머신용) — 환경 변수 템플릿
# ─────────────────────────────────────────────────────────────────────
# 이 파일은 booth-rag 의 임베딩 서버를 돌리는 머신 (예: 맥 스튜디오) 에서만
# 사용합니다. 부스 클라이언트 머신에서는 .env.example 을 복사해서 사용하세요.
#
# 듀얼 모드 (한 머신에서 bge-m3 + CodeRankEmbed 동시 서빙) 가 기본 권장.
# 한 번에 띄우기:  bash scripts/run_embedding_servers.sh
# 단일 모델만:     bash scripts/run_embedding_server.sh
#
# 이 .env 파일의 값은 단일 인스턴스 실행 시 1번째 서버 (docs, 8080) 의 기본값
# 으로 사용됩니다. 듀얼 스크립트는 코드 서버 (8081) 를 환경변수 오버라이드로
# 자동 띄움 — 이 .env 만 그대로 두면 됨.


# ─── 임베딩 모델 ────────────────────────────────────────────────────────
# 이 서버 인스턴스가 서빙할 모델 1개. 클라이언트의 EMBEDDING_LOCAL_MODEL
# 또는 EMBEDDING_CODE_MODEL 값과 정확히 일치해야 검색 일관성 유지.
#
# 다국어 + 한국어 문서용 (default — bge-m3 권장):
#   BAAI/bge-m3                            ← 1024-d, ~2.3GB, MIT
#   intfloat/multilingual-e5-large         ← 1024-d, ~2.2GB
#
# 코드 특화용 (별도 인스턴스로 분리 권장):
#   nomic-ai/CodeRankEmbed                 ← 768-d, ~520MB, MIT
#                                            (요구: trust_remote_code=true)
EMBEDDING_LOCAL_MODEL=BAAI/bge-m3

# 디바이스: auto | cpu | mps | cuda  (auto = Apple Silicon 에서 MPS 자동)
# 서버 머신이 풍족한 GPU/MPS 가지고 있으면 auto 그대로.
# 메모리 부족 / GPU 다른 작업과 공유 시 cpu 로 강제 가능 (느려지지만 안정).
EMBEDDING_DEVICE=auto

# trust_remote_code — 모델 로딩 시 모델 저장소의 커스텀 Python 코드 실행 허용.
# nomic-bert 계열 (CodeRankEmbed, nomic-embed-text-v1.5 등) 은 모델 코드 안에
# einops / 커스텀 attention 이 있어서 필수.  bge-m3 / e5 / minilm 계열은 false.
# 듀얼 스크립트 (run_embedding_servers.sh) 는 code 서버 인스턴스에 true 를
# 자동으로 넘김.  이 .env 의 docs 서버는 false 유지.
#
# 서버 부팅 시 자동으로 rotary cache 를 prewarm 해서 thread-safety 문제도
# 함께 해결합니다 (로그에 'Rotary cache prewarmed' 확인).
EMBEDDING_TRUST_REMOTE_CODE=false


# ─── 서버 바인딩 ────────────────────────────────────────────────────────
# 0.0.0.0 = LAN 어디서나 접근 가능. 한 머신에서 두 모델을 띄울 때는 포트가
# 달라야 하지만 — run_embedding_servers.sh 가 8080(docs) + 8081(code) 로
# 자동 분리하므로 여기서는 docs 측 기본값만 둠.
EMBEDDING_SERVER_HOST=0.0.0.0
EMBEDDING_SERVER_PORT=8080


# ─── 참고 — reranker / LLM / RAG 옵션은 모두 클라이언트 측 ──────────────
# Cross-encoder reranker (bge-reranker-*), OpenAI gpt-4o-mini, 모든 RAG_*
# 토글은 booth-rag 클라이언트가 직접 로드/호출합니다. 이 서버에서는
# 임베딩만 처리하므로 RAG_RERANKER_MODEL / OPENAI_API_KEY / RAG_USE_BM25
# 같은 변수는 여기 둘 필요 없음 (있어도 무시).


# ─── 사용 예 ────────────────────────────────────────────────────────────
#
# (A) 듀얼 모드 — 권장. 한 줄로 docs + code 두 서버 동시 부팅:
#
#       cp .env.server.sample .env
#       bash scripts/run_embedding_servers.sh
#       # → 8080 (bge-m3, trust_rc=false) + 8081 (CodeRankEmbed, trust_rc=true)
#       # Ctrl-C 한 번으로 둘 다 종료.
#
#     포트 / 모델 변경은 환경변수로:
#       EMBEDDING_DOCS_PORT=9000 EMBEDDING_CODE_PORT=9001 \
#       bash scripts/run_embedding_servers.sh
#
# (B) 단일 모델 — 부스 클라이언트가 RAG_DUAL_EMBEDDING=false 인 경우:
#
#       cp .env.server.sample .env
#       bash scripts/run_embedding_server.sh   # 단수형
#       # → port 8080, BAAI/bge-m3
#
# (C) 듀얼이지만 수동 — 두 터미널에 직접 띄우기 (디버깅/특수 케이스):
#
#       # 터미널 1 — docs (이 .env 그대로)
#       bash scripts/run_embedding_server.sh
#
#       # 터미널 2 — code (env 오버라이드, .env 와 분리)
#       EMBEDDING_LOCAL_MODEL=nomic-ai/CodeRankEmbed \
#       EMBEDDING_TRUST_REMOTE_CODE=true \
#       EMBEDDING_SERVER_PORT=8081 \
#       bash scripts/run_embedding_server.sh
#
#
# ─── 부스 클라이언트 측 매칭 설정 (.env.example 에서) ──────────────────
#
#   EMBEDDING_BACKEND=remote
#   EMBEDDING_LOCAL_MODEL=BAAI/bge-m3                ← docs 서버 모델과 동일
#   EMBEDDING_CODE_MODEL=nomic-ai/CodeRankEmbed      ← code 서버 모델과 동일
#   REMOTE_EMBEDDING_URL=http://<this-host>:8080
#   REMOTE_EMBEDDING_CODE_URL=http://<this-host>:8081
#   RAG_DUAL_EMBEDDING=true
#
# 모델 ID 가 양쪽 .env 에서 정확히 일치해야 검색 일관성 유지됩니다.


# ─── 동작 확인 ──────────────────────────────────────────────────────────
#   curl http://localhost:8080/info   # → {"model": "BAAI/bge-m3", "dimension": 1024, ...}
#   curl http://localhost:8081/info   # → {"model": "nomic-ai/CodeRankEmbed", "dimension": 768, ...}
#
#   curl -X POST http://localhost:8080/embed/query \
#     -H 'Content-Type: application/json' \
#     -d '{"text": "테스트 임베딩"}'
#   # → {"embedding": [0.123, ...], "dimension": 1024, "elapsed_ms": 12.3}
